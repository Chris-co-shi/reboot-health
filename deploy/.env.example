# 默认只绑定本机回环地址。
# 推荐使用 tailscale serve 暴露 127.0.0.1:3000，而不是直接监听公网或局域网。
APP_BIND_HOST=127.0.0.1

# 宿主机 PostgreSQL 17。
SPRING_DATASOURCE_URL=jdbc:postgresql://host.docker.internal:5432/reboot_health
SPRING_DATASOURCE_USERNAME=reboot_health
SPRING_DATASOURCE_PASSWORD=change-me
SPRING_FLYWAY_ENABLED=true

# Python Agent Runtime mock，M2.5-A 默认不接入真实云模型。
APP_AGENT_RUNTIME_BASE_URL=http://agent-runtime:8090
APP_AGENT_RUNTIME_TIMEOUT_MILLIS=3000

# 首台设备 bootstrap code 只能通过服务端 CLI 显式生成。
APP_DEVICE_BOOTSTRAP_GENERATE=false
APP_DEVICE_BOOTSTRAP_CODE_TTL_MINUTES=10
APP_DEVICE_BOOTSTRAP_CODE_LENGTH=24
APP_DEVICE_BOOTSTRAP_MAX_FAILURES=5
APP_DEVICE_PAIRING_CODE_TTL_MINUTES=10
APP_DEVICE_PAIRING_CODE_LENGTH=16
APP_DEVICE_ACCESS_TOKEN_TTL_MINUTES=30
APP_DEVICE_REFRESH_TOKEN_TTL_DAYS=30

# OpenAI 兼容接口。
APP_AI_BASE_URL=https://api.openai.com/v1
APP_AI_API_KEY=
APP_AI_MODEL=gpt-4.1-mini
