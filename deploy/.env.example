# 默认只绑定本机回环地址。
# 推荐使用 tailscale serve 暴露 127.0.0.1:3000，而不是直接监听公网或局域网。
APP_BIND_HOST=127.0.0.1

# 宿主机 PostgreSQL 17。
SPRING_DATASOURCE_URL=jdbc:postgresql://host.docker.internal:5432/reboot_health
SPRING_DATASOURCE_USERNAME=reboot_health
SPRING_DATASOURCE_PASSWORD=change-me
SPRING_FLYWAY_ENABLED=true

# OpenAI 兼容接口。
APP_AI_BASE_URL=https://api.openai.com/v1
APP_AI_API_KEY=
APP_AI_MODEL=gpt-4.1-mini
