# Health Agent 本地配置示例。复制为 .env 后按需填写，真实 API key 不要提交。

REBOOT_HEALTH_AGENT_PROVIDER=mock

# OpenAI-compatible Provider。mock 模式不会使用这些值。
REBOOT_HEALTH_MODEL_BASE_URL=https://api.example.com/v1
REBOOT_HEALTH_MODEL_API_KEY=replace-with-local-key
REBOOT_HEALTH_MODEL_NAME=replace-with-model-name
REBOOT_HEALTH_MODEL_TIMEOUT_SECONDS=60
REBOOT_HEALTH_MODEL_RESPONSE_FORMAT=none

# 诊断默认值必须保持安全：默认不打印 prompt、用户输入或模型正文。
REBOOT_HEALTH_MODEL_DEBUG_LOG=false
REBOOT_HEALTH_MODEL_LOG_REQUEST=none
REBOOT_HEALTH_MODEL_LOG_RESPONSE=none
REBOOT_HEALTH_AGENT_DEBUG_TRACE=false
